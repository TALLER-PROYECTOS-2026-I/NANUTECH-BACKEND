{
  "name": "nanutech-backend",
  "description": "Backend para gestión de camiones - Nanutech",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.398.0",
    "@aws-sdk/lib-dynamodb": "^3.398.0",
    "esbuild": "^0.27.4",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@testcontainers/postgresql": "^11.13.0",
    "aws-sdk-client-mock": "^2.0.0",
    "jest": "^29.2.1",
    "pg-mem": "^3.0.14"
  },
  "scripts": {
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config=jest.config.mjs",
    "test:unit": "npm run test -- __tests__/unit",
    "test:integration": "npm run test -- __tests__/integration --runInBand",
    "test:coverage": "npm run test -- --coverage",
    "migrate:up": "node-pg-migrate up     --migrations-dir db/migrations",
    "migrate:down": "node-pg-migrate down   --migrations-dir db/migrations",
    "migrate:status": "node-pg-migrate status --migrations-dir db/migrations",
    "migrate:create": "node-pg-migrate create --migrations-dir db/migrations --migration-file-language sql"
  },
  "node-pg-migrate": {
    "databaseUrl": "DATABASE_URL",
    "migrationsTable": "pgmigrations",
    "dir": "db/migrations"
  },
  "jest": {
    "testMatch": [
      "**/__tests__/**/*.[jt]s?(x)",
      "**/?(*.)+(spec|test).[jt]s?(x)",
      "**/__tests__/**/*.mjs?(x)",
      "**/?(*.)+(spec|test).mjs?(x)"
    ],
    "moduleFileExtensions": [
      "mjs",
      "js"
    ],
    "globals": {
      "jest": true
    }
  }
}
